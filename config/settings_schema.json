[
  {
    "name": "theme_info",
    "theme_name": "Racuk",
    "theme_version": "1.0",
    "theme_author": "Wyatt Jebef",
    "theme_support_email": "wyattjebef@gmail.com",
    "theme_documentation_url": "https://wyatt-jebef.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      },
      {
        "type": "header",
        "content": "Font sizes"
      },
      {
        "type": "range",
        "id": "font_size_xsmall",
        "label": "XSmall",
        "min": 8,
        "max": 16,
        "step": 1,
        "unit": "px",
        "default": 10
      },
      {
        "type": "range",
        "id": "font_size_small",
        "label": "Small",
        "min": 10,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 16
      },
      {
        "type": "range",
        "id": "font_size_medium",
        "label": "Medium",
        "min": 14,
        "max": 28,
        "step": 1,
        "unit": "px",
        "default": 18
      },
      {
        "type": "range",
        "id": "font_size_large",
        "label": "Large",
        "min": 18,
        "max": 40,
        "step": 1,
        "unit": "px",
        "default": 24
      },
      {
        "type": "range",
        "id": "font_size_xlarge",
        "label": "XLarge",
        "min": 24,
        "max": 72,
        "step": 2,
        "unit": "px",
        "default": 40
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  }
]
