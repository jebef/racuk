{% liquid
  assign primary_font_family = settings.type_primary_font.family | default: 'Jost'
  assign primary_font_fallback = settings.type_primary_font.fallback_families | default: 'sans-serif'
%}

{% style %}
  {% # Loads all font variations with display: swap %}
  {{ settings.type_primary_font | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
    --font-primary--family: {{ primary_font_family }}, {{ primary_font_fallback }};
    --font-primary--style: {{ settings.type_primary_font.style | default: 'normal' }};
    --font-primary--weight: {{ settings.type_primary_font.weight | default: 300 }};
    --page-width: {{ settings.max_page_width | default: '1200px' }};
    --page-margin: {{ settings.min_page_margin | default: 20 }}px;
    --color-background: {{ settings.background_color | default: '#ffffff' }};
    --color-foreground: {{ settings.foreground_color | default: '#000000' }};
    --style-border-radius-inputs: {{ settings.input_corner_radius | default: 0 }}px;
  }
{% endstyle %}
