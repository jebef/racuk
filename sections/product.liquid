{% comment %}
  Product page — viewport-height layout, zoom on hover, fullsize dialog,
  scrollable description, sharp selectors.
  Reference: ref/IMG_0890.png
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_images   = product.images
  assign featured_image   = current_variant.featured_image | default: product.featured_image
  assign color_option     = nil
  for option in product.options_with_values
    if option.name == 'Color' or option.name == 'Colour'
      assign color_option = option
    endif
  endfor

  assign crumb_col_handle   = collection.handle
  assign crumb_parent_title = nil
  assign crumb_parent_url   = nil
  assign crumb_leaf_title   = nil

  if section.settings.nav_menu != blank
    assign nav   = linklists[section.settings.nav_menu]
    assign found = false
    for link in nav.links
      unless found
        assign link_handle = link.url | remove: '/collections/'
        if link_handle == crumb_col_handle
          assign crumb_leaf_title = link.title
          assign found = true
        endif
        for sub in link.links
          unless found
            assign sub_handle = sub.url | remove: '/collections/'
            if sub_handle == crumb_col_handle
              assign crumb_parent_title = link.title
              assign crumb_parent_url   = link.url
              assign crumb_leaf_title   = sub.title
              assign found = true
            endif
          endunless
        endfor
      endunless
    endfor
  endif
-%}

{%- comment %} ── Breadcrumb ── {%- endcomment %}
<div class="product-page">
<nav class="product-breadcrumb" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Home</a>
  <span class="crumb__sep">/</span>
  <a href="{{ routes.collections_url }}">Collection</a>
  {%- if crumb_parent_title != nil -%}
    <span class="crumb__sep">/</span>
    <a href="{{ crumb_parent_url }}">{{ crumb_parent_title }}</a>
  {%- endif -%}
  {%- if crumb_leaf_title != nil -%}
    <span class="crumb__sep">/</span>
    <span class="crumb__current">{{ crumb_leaf_title }}</span>
  {%- elsif collection -%}
    <span class="crumb__sep">/</span>
    <span class="crumb__current">{{ collection.title }}</span>
  {%- endif -%}
</nav>

{%- comment %} ── Product layout ── {%- endcomment %}
<div class="product-layout">

  {%- comment %} ── Left: Image Gallery ── {%- endcomment %}
  <div class="product-gallery">

    <div class="gallery__image-area">
      <div class="gallery__main-wrap" id="gallery-main-wrap">
        <img
          id="gallery-main"
          class="gallery__main-img"
          src="{{ featured_image | image_url: width: 1600 }}"
          alt="{{ featured_image.alt | escape | default: product.title }}"
          width="1600"
          height="1600"
          loading="eager"
        >
      </div>

      {%- if product_images.size > 1 -%}
        <div class="gallery__thumbs-wrap">
          <button class="gallery__thumb-arrow gallery__thumb-arrow--prev" id="thumb-prev" aria-label="Previous images"></button>
          <div class="gallery__thumbnails" id="gallery-thumbs">
            <div class="gallery__thumbs-track" id="gallery-thumbs-track">
              {%- for image in product_images -%}
                <button
                  class="gallery__thumb-btn{% if forloop.first %} gallery__thumb-btn--active{% endif %}"
                  data-src="{{ image | image_url: width: 1600 }}"
                  data-alt="{{ image.alt | escape }}"
                  data-index="{{ forloop.index0 }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  <img
                    src="{{ image | image_url: width: 200 }}"
                    alt="{{ image.alt | escape }}"
                    width="80"
                    height="80"
                    loading="lazy"
                  >
                </button>
              {%- endfor -%}
            </div>
          </div>
          <button class="gallery__thumb-arrow gallery__thumb-arrow--next" id="thumb-next" aria-label="Next images"></button>
        </div>
      {%- endif -%}
    </div>

  </div>

  {%- comment %} ── Right: Product Info ── {%- endcomment %}
  <div class="product-info">

    <h1 class="product-info__title">{{ product.title }}</h1>

    <p class="product-info__price">
      <span id="product-price">{{ current_variant.price | money }}</span>
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <s class="product-info__compare-price">{{ current_variant.compare_at_price | money }}</s>
      {%- endif -%}
    </p>

    {%- if product.description != blank -%}
      <div class="product-info__description">
        {{ product.description }}
      </div>
    {%- endif -%}

    {%- comment %} Color swatches {%- endcomment %}
    {%- if color_option -%}
      <div class="product-info__section">
        <p class="product-info__label">Colors:</p>
        <div class="product-swatches" role="group" aria-label="Color options">
          {%- for value in color_option.values -%}
            {%- liquid
              assign swatch_active = false
              if current_variant.options contains value
                assign swatch_active = true
              endif
              assign swatch_handle = value | handleize
            -%}
            <button
              class="swatch{% if swatch_active %} swatch--active{% endif %}"
              data-option-name="{{ color_option.name }}"
              data-option-value="{{ value }}"
              aria-label="{{ value }}"
              title="{{ value }}"
              style="background-color: {{ swatch_handle }};"
            ></button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment %} Variant form {%- endcomment %}
    {%- form 'product', product, id: 'product-form' -%}
      <input type="hidden" name="id" id="variant-id" value="{{ current_variant.id }}">

      {% comment %}
      <div class="product-selectors">
        {%- for option in product.options_with_values -%}
          {%- unless option.name == 'Color' or option.name == 'Colour' -%}
            <div class="product-selector">
              <label class="product-selector__label" for="option-{{ option.position }}">
                {{ option.name }}:
              </label>
              <div class="product-selector__select-wrap">
                <select class="product-selector__select" id="option-{{ option.position }}" data-option-index="{{ option.position }}">
                  {%- for value in option.values -%}
                    <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>
                      {{ value }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            </div>
          {%- endunless -%}
        {%- endfor -%}

        <div class="product-selector">
          <label class="product-selector__label" for="quantity">Qty:</label>
          <div class="product-selector__select-wrap">
            <select class="product-selector__select" id="quantity" name="quantity">
              {%- for i in (1..10) -%}
                <option value="{{ i }}">{{ i }}</option>
              {%- endfor -%}
            </select>
          </div>
        </div>
      </div>
      {% endcomment %}

      <button
        type="submit"
        class="product-buy-btn"
        id="add-to-cart"
        {% unless current_variant.available %}disabled{% endunless %}
      >
        {%- if current_variant.available -%}Purchase{%- else -%}Sold Out{%- endif -%}
      </button>

    {%- endform -%}

  </div>
</div>
</div>

<script>
  (function () {
    var productData    = {{ product.variants | json }};
    var variantIdInput = document.getElementById('variant-id');
    var priceEl        = document.getElementById('product-price');
    var addToCartBtn   = document.getElementById('add-to-cart');
    var mainImg        = document.getElementById('gallery-main');
    var thumbBtns      = document.querySelectorAll('.gallery__thumb-btn');
    var swatches       = document.querySelectorAll('.swatch');
    var selects        = document.querySelectorAll('.product-selector__select[data-option-index]');
    // ── Thumbnail navigator ──
    var thumbPrev   = document.getElementById('thumb-prev');
    var thumbNext   = document.getElementById('thumb-next');
    var thumbTrack  = document.getElementById('gallery-thumbs-track');
    var thumbOffset = 0;
    var VISIBLE     = 3;
    var STEP        = 2;
    var THUMB_PX    = 80; // matches CSS width/height of each thumb button img
    var THUMB_GAP   = 8;  // 0.5rem at 16px base

    function updateThumbs() {
      if (thumbTrack) {
        var isMobile = window.innerWidth <= 768;
        var px = thumbOffset * (THUMB_PX + THUMB_GAP);
        thumbTrack.style.transform = isMobile
          ? 'translateX(-' + px + 'px)'
          : 'translateY(-' + px + 'px)';
      }
      var maxOffset = Math.max(0, thumbBtns.length - VISIBLE);
      if (thumbPrev) thumbPrev.style.opacity = thumbOffset === 0 ? '0.2' : '1';
      if (thumbNext) thumbNext.style.opacity = thumbOffset >= maxOffset ? '0.2' : '1';
    }

    if (thumbBtns.length > 0) updateThumbs();

    if (thumbPrev) thumbPrev.addEventListener('click', function () {
      if (thumbOffset > 0) { thumbOffset = Math.max(0, thumbOffset - STEP); updateThumbs(); }
    });
    if (thumbNext) thumbNext.addEventListener('click', function () {
      var maxOffset = Math.max(0, thumbBtns.length - VISIBLE);
      if (thumbOffset < maxOffset) { thumbOffset = Math.min(maxOffset, thumbOffset + STEP); updateThumbs(); }
    });

    thumbBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        thumbBtns.forEach(function (b) { b.classList.remove('gallery__thumb-btn--active'); });
        btn.classList.add('gallery__thumb-btn--active');
        mainImg.src = btn.dataset.src;
        mainImg.alt = btn.dataset.alt;
      });
    });

    // ── Variant selection ──
    function findVariant() {
      var selectedValues = [];
      for (var i = 0; i < {{ product.options.size }}; i++) {
        selectedValues.push(null);
      }
      selects.forEach(function (sel) {
        selectedValues[parseInt(sel.dataset.optionIndex, 10) - 1] = sel.value;
      });
      var activeSwatch = document.querySelector('.swatch--active');
      if (activeSwatch) {
        var colorName = activeSwatch.dataset.optionName;
        var opts = {{ product.options_with_values | json }};
        opts.forEach(function (opt, i) {
          if (opt.name === colorName) selectedValues[i] = activeSwatch.dataset.optionValue;
        });
      }
      return productData.find(function (v) {
        return v.options.every(function (opt, i) {
          return selectedValues[i] === null || opt === selectedValues[i];
        });
      });
    }

    function updateVariant(variant) {
      if (!variant) return;
      variantIdInput.value = variant.id;
      if (priceEl) priceEl.textContent = formatMoney(variant.price);
      if (addToCartBtn) {
        addToCartBtn.disabled = !variant.available;
        addToCartBtn.textContent = variant.available ? 'Purchase' : 'Sold Out';
      }
      if (variant.featured_image && mainImg) {
        mainImg.src = variant.featured_image.src;
        mainImg.alt = variant.featured_image.alt || '';
      }
    }

    function formatMoney(cents) {
      return '$' + (cents / 100).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    swatches.forEach(function (sw) {
      sw.addEventListener('click', function () {
        swatches.forEach(function (s) { s.classList.remove('swatch--active'); });
        sw.classList.add('swatch--active');
        updateVariant(findVariant());
      });
    });

    selects.forEach(function (sel) {
      sel.addEventListener('change', function () { updateVariant(findVariant()); });
    });

  })();
</script>

{% stylesheet %}
  /* ── Breadcrumb — matches collection pages exactly ── */
  .product-breadcrumb {
    font-size: var(--font-size-small);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground);
    padding-block: 1.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .product-breadcrumb a {
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;
  }

  .product-breadcrumb a:hover { opacity: 0.5; }
  .crumb__sep     { opacity: 0.3; }
  .crumb__current { opacity: 0.45; }

  /* ── Two-column layout — capped to remaining viewport space ── */
  .product-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    height: calc(100svh - 10vh - 8rem);
    overflow: hidden;
  }

  /* ── Gallery ── */
  .product-gallery {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    overflow: hidden;
  }

  .gallery__image-area {
    display: grid;
    grid-template-columns: 1fr 80px;
    gap: 0.75rem;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .gallery__main-wrap {
    position: relative;
    height: 100%;
    min-height: 0;
    overflow: hidden;
  }

  /* Thumbnails strip + arrows */
  .gallery__thumbs-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    justify-content: center;
  }

  /* Clip to exactly 3 thumbnails; inner track slides via transform */
  .gallery__thumbnails {
    overflow: hidden;
    /* 3 × 80px thumbs + 2 × 0.5rem gaps */
    height: calc(3 * 80px + 2 * 0.5rem);
  }

  .gallery__thumbs-track {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gallery__thumb-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: block;
    flex-shrink: 0;
    opacity: 0.6;
    transition: opacity 0.2s ease, box-shadow 0.2s ease;
  }

  .gallery__thumb-btn img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    display: block;
  }

  .gallery__thumb-btn:hover,
  .gallery__thumb-btn--active {
    opacity: 1;
    /* inset shadow doesn't affect layout dimensions */
    box-shadow: inset 0 0 0 1px var(--color-foreground);
  }

  /* Arrows — match carousel chevron style */
  .gallery__thumb-arrow {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0, 0, 0, 0.25);
    transition: color 0.2s ease;
    flex-shrink: 0;
  }

  .gallery__thumb-arrow:hover { color: var(--color-foreground); }

  .gallery__thumb-arrow::before {
    content: '';
    display: block;
    width: 9px;
    height: 9px;
    border-top: 1.5px solid currentColor;
    border-right: 1.5px solid currentColor;
  }

  .gallery__thumb-arrow--prev::before { transform: rotate(-45deg); }
  .gallery__thumb-arrow--next::before { transform: rotate(135deg); }

  @media (max-width: 768px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
      height: auto;
      max-height: none;
      overflow-y: auto;
    }

    .product-gallery {
      height: auto;
    }

    .product-info {
      padding-bottom: 3rem;
    }

    .gallery__image-area {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      height: auto;
    }

    /* Concrete height so the absolutely-positioned main image fills it */
    .gallery__main-wrap {
      height: 100vw;
    }

    .gallery__thumbs-wrap {
      flex-direction: row;
    }

    /* Horizontal clip: 3 × 80px + 2 gaps */
    .gallery__thumbnails {
      height: auto;
      width: calc(3 * 80px + 2 * 0.5rem);
    }

    .gallery__thumbs-track {
      flex-direction: row;
    }

    .gallery__thumb-arrow--prev::before { transform: rotate(-135deg); }
    .gallery__thumb-arrow--next::before { transform: rotate(45deg); }
  }

/* ── Product info ── */
  .product-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 0;
    overflow: hidden;
  }

  .product-info__title {
    font-size: var(--font-size-medium);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1.2;
    flex-shrink: 0;
  }

  .product-info__price {
    font-size: var(--font-size-small);
    letter-spacing: 0.05em;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .product-info__compare-price {
    opacity: 0.4;
  }

  .product-info__description {
    font-size: var(--font-size-small);
    line-height: 1.8;
    letter-spacing: 0.02em;
  }

  /* Rich text headings within description */
  .product-info__description h2,
  .product-info__description h3,
  .product-info__description h4 {
    font-size: var(--font-size-xsmall);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.4em;
    margin-top: 1em;
  }

  .product-info__description ul,
  .product-info__description ol {
    padding-left: 1.2em;
    margin: 0;
  }

  .product-info__description li {
    margin-bottom: 0.15em;
  }

  /* Color swatches section */
  .product-info__section {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .product-info__label {
    font-size: var(--font-size-xsmall);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .product-swatches {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .swatch {
    width: 20px;
    height: 20px;
    border: 1px solid transparent;
    border-radius: 0;
    cursor: pointer;
    padding: 0;
    outline-offset: 2px;
    transition: outline 0.15s ease;
  }

  .swatch--active,
  .swatch:hover {
    outline: 1.5px solid var(--color-foreground);
  }

  /* ── Variant selectors ── */
  .product-selectors {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-shrink: 0;
    align-self: flex-start;
  }

  .product-selector {
    display: grid;
    grid-template-columns: 60px 140px;
    align-items: center;
    gap: 0.5rem;
  }

  .product-selector__label {
    font-size: var(--font-size-xsmall);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 600;
    text-align: right;
  }

  .product-selector__select-wrap {
    position: relative;
  }

  .product-selector__select {
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    background-color: var(--color-background);
    color: var(--color-foreground);
    border: 1px solid color-mix(in srgb, var(--color-foreground) 35%, transparent);
    border-radius: 0;
    padding: 0.35rem 1.8rem 0.35rem 0.5rem;
    font-size: var(--font-size-xsmall);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
  }

  .product-selector__select:focus {
    outline: 1px solid var(--color-foreground);
    border-color: var(--color-foreground);
  }

  .product-selector__select-wrap::after {
    content: '▾';
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    font-size: 0.6rem;
    opacity: 0.5;
  }

  /* ── Buy button ── */
  .product-buy-btn {
    display: block;
    width: fit-content;
    min-width: 200px;
    margin: 1rem auto 0;
    padding: 0.75rem 2rem;
    background-color: var(--color-foreground);
    color: var(--color-background);
    border: none;
    border-radius: 0;
    font-size: var(--font-size-xsmall);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s ease;
    font-family: inherit;
    flex-shrink: 0;
  }

  .product-buy-btn:hover:not(:disabled) { opacity: 0.8; }
  .product-buy-btn:disabled { opacity: 0.35; cursor: not-allowed; }

{% endstylesheet %}

{% style %}
  /*
   * Inlined to bypass the compiled stylesheet bundle and the global
   * img { height: auto } reset. position: absolute + inset: 0 gives the
   * image concrete dimensions so object-fit: contain can scale correctly.
   */
  .gallery__main-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
{% endstyle %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "link_list",
      "id": "nav_menu",
      "label": "Navigation menu",
      "info": "Same menu used on the collection pages — used to build the breadcrumb trail."
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
