{% comment %}
  List-collections page (/collections).
  Shows top-level category cards driven by the nav menu.
  Breadcrumb: Home / Collection
{% endcomment %}

{%- liquid
  assign nav = nil
  if section.settings.nav_menu != blank
    assign nav = linklists[section.settings.nav_menu]
  endif
-%}

<nav class="collection-breadcrumb" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Home</a>
  <span class="crumb__sep">/</span>
  <span class="crumb__current">Collection</span>
</nav>

<div class="col-card-grid">
  {%- if nav != nil and nav.links.size > 0 -%}

    {%- for link in nav.links -%}
      {%- assign col_handle = link.url | remove: '/collections/' -%}
      {%- assign col = collections[col_handle] -%}
      <a class="col-card" href="{{ link.url }}">
        <div class="col-card__image-wrap">
          {%- if col.featured_image -%}
            <img
              class="col-card__img"
              src="{{ col.featured_image | image_url: width: 800 }}"
              alt="{{ col.featured_image.alt | escape | default: col.title }}"
              width="800"
              height="800"
              loading="lazy"
            >
          {%- else -%}
            <div class="col-card__placeholder">
              {{ 'collection-1' | placeholder_svg_tag: 'col-card__placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
        <div class="col-card__info">
          <span class="col-card__title">{{ link.title }}</span>
        </div>
      </a>
    {%- endfor -%}

  {%- else -%}

    {%- comment %} Fallback: show all collections if no menu configured {%- endcomment %}
    {%- for col in collections -%}
      <a class="col-card" href="{{ col.url }}">
        <div class="col-card__image-wrap">
          {%- if col.featured_image -%}
            <img
              class="col-card__img"
              src="{{ col.featured_image | image_url: width: 800 }}"
              alt="{{ col.featured_image.alt | escape | default: col.title }}"
              width="800"
              height="800"
              loading="lazy"
            >
          {%- else -%}
            <div class="col-card__placeholder">
              {{ 'collection-1' | placeholder_svg_tag: 'col-card__placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
        <div class="col-card__info">
          <span class="col-card__title">{{ col.title }}</span>
        </div>
      </a>
    {%- endfor -%}

  {%- endif -%}
</div>

{% stylesheet %}
  /* ── Breadcrumb (shared with collection page) ── */
  .collection-breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-block: 1.5rem 2rem;
    font-size: var(--font-size-small);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .collection-breadcrumb a {
    text-decoration: none;
    color: var(--color-foreground);
    transition: opacity 0.15s ease;
  }

  .collection-breadcrumb a:hover { opacity: 0.5; }
  .crumb__sep   { opacity: 0.3; }
  .crumb__current { opacity: 0.45; }

  /* ── Card grid ── */
  .col-card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-bottom: 4rem;
  }

  @media (max-width: 540px) {
    .col-card-grid { grid-template-columns: 1fr; }
  }

  /* ── Collection card ── */
  .col-card {
    display: block;
    text-decoration: none;
    color: var(--color-foreground);
  }

  .col-card__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: color-mix(in srgb, var(--color-foreground) 4%, var(--color-background));
  }

  .col-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }

  .col-card:hover .col-card__img { opacity: 0.5; }
  .col-card:hover .col-card__title { opacity: 0.5; }

  .col-card__placeholder,
  .col-card__placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.12;
  }

  .col-card__info {
    padding: 0.6rem 0 1rem;
  }

  .col-card__title {
    font-size: var(--font-size-small);
    transition: opacity 0.2s ease;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.4;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collections_grid",
  "settings": [
    {
      "type": "link_list",
      "id": "nav_menu",
      "label": "Navigation menu",
      "info": "Top-level links become category cards. Should match your main navbar menu."
    }
  ]
}
{% endschema %}
